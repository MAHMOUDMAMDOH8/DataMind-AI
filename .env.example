TRINO_URL=http://localhost:8085
MINIO_CONSOLE_URL=http://localhost:9001
KAFKA_UI_URL=http://localhost:8090
NIFI_HTTP_URL=http://localhost:8082/nifi
SPARK_UI_URL=http://localhost:8080
