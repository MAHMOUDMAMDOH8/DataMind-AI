# DataMind AI — local environment defaults
# Copy to .env and adjust if needed:
#   cp .env.example .env
# docker compose reads .env automatically.

COMPOSE_PROJECT_NAME=datamind-ai

# ── MinIO / S3 ──────────────────────────────────────────────────────────────
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=password
AWS_REGION=us-east-1

# ── Shared Postgres ──────────────────────────────────────────────────────────
POSTGRES_ROOT_PASSWORD=rootpassword

# ── Nessie ──────────────────────────────────────────────────────────────────
NESSIE_DB=nessie
NESSIE_DB_USER=nessie
NESSIE_DB_PASSWORD=nessie

# ── Airflow ──────────────────────────────────────────────────────────────────
AIRFLOW_DB=airflow
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow
# Generate your own Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=46BKJoQYlPPOexq0OhDZnLXN8zTopXNOCAS3h9gw9UiY=

# ── NiFi ─────────────────────────────────────────────────────────────────────
NIFI_ADMIN_USERNAME=admin
NIFI_ADMIN_PASSWORD=ctsBtRBKHRAx69EqUghvvgEvjnaLjFEB

# ── OpenMetadata ─────────────────────────────────────────────────────────────
OPENMETADATA_MYSQL_ROOT_PASSWORD=password

# ── Service URLs (for local access) ─────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081
